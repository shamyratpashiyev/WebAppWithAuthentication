{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "AllowedOrigins": [
    "http://webappwithauthenticationui.runasp.net"
  ],
  "DefaultCorsPolicy": "DefaultCorsPolicy",
  "ConnectionStrings": {
    "DefaultConnection": ""
  },
  "JwtSettings": {
    "Issuer": "WebApiWithAuthenticationIssuer",
    "Audience": "WebApiWithAuthenticationAudience",
    "ExpirationTimeInSec": 1500,
    "RefreshExpirationTimeInDays": 30,
    "SecretKeyId": "Authentication:Schemes:Bearer:SigningKeys:0:Value"
  },
  "CookieSettings": {
    "Secure": false
  },
  "EmailSettings": {
    "Host": "smtp.gmail.com",
    "Port": 587
  },
  "Ui": {
    "BaseUrl": "http://webappwithauthenticationui.runasp.net",
    "EmailConfirmation": {
      "Path": "email-confirmation",
      "UserId": "userId",
      "Token": "token"
    },
    "PasswordReset": {
      "Path": "password-reset",
      "UserId": "userId",
      "Token": "token"
    }
  }
}
